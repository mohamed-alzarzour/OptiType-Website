---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Page Not Found | OptiType">
  <div class="min-h-[75vh] flex flex-col items-center justify-center text-center px-5 relative z-10">
    
    <div class="relative mb-6 tilt">
      <!-- Glow effect behind the 404 -->
      <div class="absolute inset-0 bg-blue/20 blur-[100px] rounded-full"></div>
      <h1 class="text-9xl md:text-[15rem] font-black tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-blue to-green drop-shadow-2xl animate-pulse" style="line-height: 1;">
        404
      </h1>
    </div>
    
    <h2 class="text-3xl md:text-5xl font-bold mb-6 tracking-tight" style="color:var(--c-text)">
      Lost in the Neural Network
    </h2>
    
    <p class="text-lg md:text-xl max-w-lg mb-12" style="color:var(--c-text3)">
      The eye-tracking system couldn't locate the page you're looking for. It might have been moved or never existed.
    </p>
    
    <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/en/`} class="group relative inline-flex items-center justify-center px-8 py-4 font-bold text-white transition-all duration-300 rounded-xl">
      <!-- Animated border/glow -->
      <div class="absolute -inset-0.5 bg-gradient-to-r from-blue to-green rounded-xl blur opacity-50 group-hover:opacity-100 transition duration-300"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-blue to-green rounded-xl opacity-90 group-hover:opacity-100 transition duration-300"></div>
      <span class="relative flex items-center gap-2">
        <svg class="w-5 h-5 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Return to Safety
      </span>
    </a>
  </div>
</Layout>
