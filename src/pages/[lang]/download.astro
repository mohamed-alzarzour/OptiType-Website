---
import Layout from '../../layouts/Layout.astro';
import { languages, useTranslations } from '../../i18n/ui';
export function getStaticPaths(){return Object.keys(languages).map(l=>({params:{lang:l}}));}
const {lang}=Astro.params; const t=useTranslations(lang as any);
const V="7.0.0";
const GH=`https://github.com/moha5o/OptiType/releases/download/v${V}`;
---
<Layout title={`OptiType - ${t('nav.download')}`}>
<div class="max-w-5xl mx-auto py-20 a-up">
	<div class="text-center mb-16">
		<p class="text-xs font-bold tracking-[0.2em] uppercase mb-4" style="color:var(--c-blue)">Download</p>
		<h1 class="text-4xl md:text-5xl font-black mb-4" style="color:var(--c-text)">{t('dl.title')}</h1>
		<p class="text-lg max-w-xl mx-auto" style="color:var(--c-text2)">{t('dl.desc')}</p>
		<div class="inline-flex items-center gap-2 mt-5 px-4 py-2 rounded-full glass text-sm font-medium">
			<span class="w-2 h-2 rounded-full animate-pulse" style="background:var(--c-green)"></span>
			<span style="color:var(--c-green)">Version {V}</span>
		</div>
	</div>
	<div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
		<!-- Windows -->
		<div class="tilt glass rounded-3xl p-8 flex flex-col items-center text-center group relative overflow-hidden">
			<div class="absolute inset-0 bg-gradient-to-b opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background:linear-gradient(to bottom,rgba(24,160,248,0.04),transparent)"></div>
			<div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform" style="background:var(--c-surface)">
				<svg class="w-8 h-8" style="color:var(--c-text2)" fill="currentColor" viewBox="0 0 88 88"><path d="M0 12.402l35.687-4.86.016 34.423-35.67.203zm35.67 33.529l.028 34.453L.028 75.48V46.06zM40.336 6.136L88 0v42.07l-47.664-.54zm47.664 40.404L88 88l-47.664-6.85V46.54z"/></svg>
			</div>
			<h2 class="text-2xl font-bold mb-2" style="color:var(--c-text)">Windows</h2>
			<p class="text-sm mb-6" style="color:var(--c-text2)">Windows 10 / 11 (64-bit)</p>
			<a href={`${GH}/OptiType_Setup.exe`} class="w-full py-4 bg-gradient-to-r from-blue to-cyan text-white font-bold rounded-xl transition-all hover:shadow-[0_4px_20px_rgba(24,160,248,0.3)] hover:-translate-y-0.5 flex items-center justify-center gap-2 relative z-10">
				<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
				Download .exe
			</a>
			<div class="mt-6 text-sm text-left w-full relative z-10" style="color:var(--c-text3)">
				<p class="font-bold uppercase tracking-wider text-xs mb-2">{t('dl.requirements')}</p>
				<ul class="space-y-1"><li>• Standard Webcam</li><li>• 4GB RAM</li><li>• 500MB disk space</li></ul>
			</div>
		</div>
		<!-- Linux -->
		<div class="tilt glass rounded-3xl p-8 flex flex-col items-center text-center group relative overflow-hidden">
			<div class="absolute inset-0 bg-gradient-to-b opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background:linear-gradient(to bottom,rgba(65,207,110,0.04),transparent)"></div>
			<div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform" style="background:var(--c-surface)">
				<svg class="w-8 h-8" style="color:var(--c-text2)" fill="currentColor" viewBox="0 0 448 512"><path d="M220.8 123.3c1 .5 1.8 1.7 3 1.7 1.1 0 2.8-.4 2.9-1.5.2-1.4-1.9-2.3-3.2-2.9-1.7-.7-3.9-1-5.5-.1-.4.2-.8.7-.6 1.1.3 1.3 2.3 1.1 3.4 1.7zm-21.9 1.7c1.2 0 2-1.2 3-1.7 1.1-.6 3.1-.4 3.5-1.6.2-.4-.2-.9-.6-1.1-1.6-.9-3.8-.6-5.5.1-1.3.6-3.4 1.5-3.2 2.9.1 1 1.8 1.5 2.8 1.4zM420 403.8c-3.6-4-5.3-11.6-7.2-19.7-1.8-8.1-3.9-16.8-10.5-22.4-1.3-1.1-2.6-2.1-4-2.9-1.3-.8-2.7-1.5-4.1-2 9.2-27.3 5.6-54.5-3.7-79.1-11.4-30.1-31.3-56.4-46.5-74.4-17.1-21.5-33.7-41.9-33.4-72C311.1 85.4 315.7.1 234.8 0 132.4-.2 158 103.4 156.9 135.2c-1.7 23.4-6.4 41.8-22.5 64.7-18.9 22.5-45.5 58.8-58.1 96.7-6 17.9-8.8 36.1-6.2 53.3-6.5 5.8-11.4 14.7-16.6 20.2-4.2 4.3-10.3 5.9-17 8.3s-14 6-18.5 14.5c-2.1 3.9-2.8 8.1-2.8 12.4 0 3.9.6 7.9 1.2 11.8 1.2 8.1 2.6 15.7.8 20.8-5.2 14.4-5.9 24.4-2.2 31.7 3.8 7.1 11.4 10.4 20.7 12.8 17.7 4.5 42.3 2.9 61.4 12.5 29.4 14.1 51.7 18.7 71.1 5.9 9.4-6.1 17.4-15.5 25.5-22.2 3.2 1.6 6.5 2.3 9.6 2.3 8.4 0 16-4.8 22.4-9.6 8.6-6.4 15.2-12 24.8-14.9 20.3-6.2 41.8-1.6 60-12.4 9-5.4 16.3-14.6 17.8-26.7 1-8-1.3-16.8-6.2-25.2zM228.2 43.4c35.3-.3 48.5 32 49.7 57.6 1.2 26.4-2.4 47.3-19.3 72.9-6.7-6.9-14.6-12.1-24.2-14.4-5.1-1.2-10.5-1.6-15.8-1.3-4.6.3-9 1.2-13.3 2.5-1.4.4-2.7.9-4 1.4-10.4-9.4-21.4-17-32.3-22.7 1.4-7.7 3.5-15 6.6-21.7 8.6-18.5 20.3-32.2 34.1-43.6 5.8-4.8 12.1-8.9 18.5-12.7 3.7 4.6 7.1 9.7 10 15.3-5.4 4.2-10.1 9.4-13.6 15.5-3.5 6.1-5.7 13-5.7 20.3 0 14.4 8.5 27.1 21.4 33.3 3.5 1.7 7.4 2.7 11.4 2.7 14.4 0 26.2-11.7 26.2-26.2 0-14.4-11.7-26.2-26.2-26.2-4 0-7.8.9-11.2 2.5-2.4-4.6-5.4-8.9-8.8-12.8 8.5-5.5 17.1-10 25.5-13.4z"/></svg>
			</div>
			<h2 class="text-2xl font-bold mb-2" style="color:var(--c-text)">Linux</h2>
			<p class="text-sm mb-5" style="color:var(--c-text2)">Ubuntu 20.04+ / Debian 12+</p>
			<a href={`${GH}/OptiType-x86_64.AppImage`} class="w-full py-4 bg-gradient-to-r from-green to-blue text-white font-bold rounded-xl transition-all hover:shadow-[0_4px_20px_rgba(65,207,110,0.3)] hover:-translate-y-0.5 flex items-center justify-center gap-2 mb-3 relative z-10">
				<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
				AppImage <span class="text-xs ml-1 px-2 py-0.5 rounded-full" style="background:rgba(255,255,255,0.2)">{t('dl.recommended')}</span>
			</a>
			<div class="flex gap-3 w-full">
				<a href={`${GH}/optitype_${V}_amd64.deb`} class="flex-1 py-3 rounded-xl text-sm font-medium flex items-center justify-center gap-1 transition-all relative z-10" style="background:var(--c-surface);color:var(--c-text2);border:1px solid var(--c-border)">.deb <span class="text-xs" style="color:var(--c-text3)">146MB</span></a>
				<a href={`${GH}/OptiType_linux_x86_64.tar.gz`} class="flex-1 py-3 rounded-xl text-sm font-medium flex items-center justify-center gap-1 transition-all relative z-10" style="background:var(--c-surface);color:var(--c-text2);border:1px solid var(--c-border)">.tar.gz <span class="text-xs" style="color:var(--c-text3)">192MB</span></a>
			</div>
			<div class="mt-6 text-sm text-left w-full relative z-10" style="color:var(--c-text3)">
				<p class="font-bold uppercase tracking-wider text-xs mb-2">{t('dl.requirements')}</p>
				<ul class="space-y-1"><li>• Standard Webcam</li><li>• glibc 2.31+</li><li>• 500MB disk space</li></ul>
			</div>
		</div>
	</div>
	<div class="text-center mt-10">
		<a href="https://github.com/mohamed-alzarzour/OptiType" target="_blank" class="inline-flex items-center gap-2 text-sm transition-colors hover:opacity-70" style="color:var(--c-text3)">
			<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
			{t('dl.source')}
		</a>
	</div>
</div>
</Layout>
