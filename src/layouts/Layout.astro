---
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import '../styles/global.css';
interface Props { title: string; }
const { title } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!doctype html>
<html lang={lang} dir="ltr" data-theme="dark">
<head>
	<meta charset="UTF-8" />
	<meta name="description" content="OptiType — ML-powered eye-tracking typing system. Type with your eyes using any webcam." />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<link rel="icon" type="image/png" href={`${base}/favicon.png`} />
	<link rel="apple-touch-icon" href={`${base}/favicon.png`} />
	<meta name="theme-color" content="#06080e" />
	<title>{title}</title>
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body class="min-h-screen flex flex-col">
	<canvas id="neural-bg"></canvas>
	<div id="cursor-glow"></div>

	<!-- NAV -->
	<header id="nav" class="fixed top-0 w-full z-50 transition-all duration-500">
		<div class="max-w-6xl mx-auto flex justify-between items-center px-5 py-5 transition-all duration-500">
			<a href={`${base}/${lang}/`} class="flex items-center gap-3 group">
				<div class="relative">
					<img src={`${base}/favicon.png`} alt="" class="w-8 h-8 rounded-lg group-hover:scale-110 transition-transform duration-300" />
					<div class="absolute inset-0 rounded-lg bg-blue/30 blur-md opacity-0 group-hover:opacity-100 transition-opacity"></div>
				</div>
				<span class="text-lg font-extrabold tracking-tight"><span style="color:var(--c-text)">Opti</span><span class="text-grad">Type</span></span>
			</a>
			<nav class="hidden md:flex items-center gap-1 glass rounded-full px-2 py-1.5">
				<a href={`${base}/${lang}/`} class="px-4 py-2 rounded-full text-sm font-medium transition-all hover:bg-blue/10" style="color:var(--c-text2)">{t('nav.home')}</a>
				<a href={`${base}/${lang}/about`} class="px-4 py-2 rounded-full text-sm font-medium transition-all hover:bg-blue/10" style="color:var(--c-text2)">{t('nav.about')}</a>
				<a href={`${base}/${lang}/download`} class="px-4 py-2 rounded-full text-sm font-medium transition-all hover:bg-blue/10" style="color:var(--c-text2)">{t('nav.download')}</a>
				<a href={`${base}/${lang}/docs`} class="px-4 py-2 rounded-full text-sm font-medium transition-all hover:bg-blue/10" style="color:var(--c-text2)">{t('nav.docs')}</a>
			</nav>
			<div class="flex items-center gap-3">
				<div class="hidden sm:flex items-center gap-1 glass rounded-full p-1 text-xs font-semibold">
					<a href={`${base}/en/`} class={`px-3 py-1.5 rounded-full transition-all ${lang === 'en' ? 'bg-gradient-to-r from-blue to-green text-white shadow-lg' : ''}`} style={lang !== 'en' ? 'color:var(--c-text3)' : ''}>EN</a>
					<a href={`${base}/tr/`} class={`px-3 py-1.5 rounded-full transition-all ${lang === 'tr' ? 'bg-gradient-to-r from-blue to-green text-white shadow-lg' : ''}`} style={lang !== 'tr' ? 'color:var(--c-text3)' : ''}>TR</a>
				</div>
				<button id="theme-btn" class="theme-toggle" aria-label="Toggle theme">
					<span class="icon-sun">☀️</span>
					<span class="icon-moon">🌙</span>
				</button>
				<button id="mob-btn" class="md:hidden w-10 h-10 flex items-center justify-center rounded-xl glass" style="color:var(--c-text2)" aria-label="Menu">
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
				</button>
			</div>
		</div>
	</header>

	<!-- MOBILE MENU -->
	<div id="mob-menu" class="fixed inset-0 z-[60] pointer-events-none">
		<div id="mob-bd" class="absolute inset-0 bg-black/70 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>
		<div id="mob-pn" class="absolute top-0 right-0 h-full w-72 transform translate-x-full transition-transform duration-300 flex flex-col" style="background:var(--c-bg2); border-left:1px solid var(--c-border)">
			<div class="flex justify-between items-center p-5" style="border-bottom:1px solid var(--c-border)">
				<span class="font-bold" style="color:var(--c-text)">{t('menu.title')}</span>
				<button id="mob-cl" class="w-8 h-8 flex items-center justify-center rounded-lg" style="color:var(--c-text2)">
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
				</button>
			</div>
			<div class="p-4 sm:hidden" style="border-bottom:1px solid var(--c-border)">
				<div class="flex items-center gap-1 glass rounded-xl p-1 text-sm font-semibold">
					<a href={`${base}/en/`} class={`flex-1 text-center py-2 rounded-lg transition-all ${lang === 'en' ? 'bg-gradient-to-r from-blue to-green text-white shadow-lg' : ''}`} style={lang !== 'en' ? 'color:var(--c-text3)' : ''}>EN</a>
					<a href={`${base}/tr/`} class={`flex-1 text-center py-2 rounded-lg transition-all ${lang === 'tr' ? 'bg-gradient-to-r from-blue to-green text-white shadow-lg' : ''}`} style={lang !== 'tr' ? 'color:var(--c-text3)' : ''}>TR</a>
				</div>
			</div>
			<nav class="flex flex-col p-4 gap-1">
				<a href={`${base}/${lang}/`} class="px-4 py-3 rounded-xl font-medium transition-all" style="color:var(--c-text2)">{t('nav.home')}</a>
				<a href={`${base}/${lang}/about`} class="px-4 py-3 rounded-xl font-medium transition-all" style="color:var(--c-text2)">{t('nav.about')}</a>
				<a href={`${base}/${lang}/download`} class="px-4 py-3 rounded-xl font-medium transition-all" style="color:var(--c-text2)">{t('nav.download')}</a>
				<a href={`${base}/${lang}/docs`} class="px-4 py-3 rounded-xl font-medium transition-all" style="color:var(--c-text2)">{t('nav.docs')}</a>
			</nav>
			<div class="mt-auto p-4" style="border-top:1px solid var(--c-border)">
				<a href={`${base}/${lang}/download`} class="block w-full py-3 bg-gradient-to-r from-blue to-green text-white rounded-xl font-bold text-center">Download</a>
			</div>
		</div>
	</div>

	<main class="flex-grow pt-20"><slot /></main>

	<!-- FOOTER -->
	<footer class="rv" style="border-top:1px solid var(--c-border); background:var(--c-bg2); transition:background .5s,border-color .5s">
		<div class="max-w-6xl mx-auto px-5 py-10">
			<div class="flex flex-col md:flex-row justify-between items-start gap-6">
				<div>
					<div class="flex items-center gap-2 mb-2"><img src={`${base}/favicon.png`} alt="" class="w-5 h-5 rounded"><span class="font-bold" style="color:var(--c-text)">OptiType</span></div>
					<p class="text-sm max-w-xs" style="color:var(--c-text3)">ML-powered eye-tracking typing system. Free & open-source.</p>
				</div>
				<div class="flex items-center gap-5">
					<a href="https://github.com/mohamed-alzarzour" target="_blank" style="color:var(--c-text3)" class="hover:opacity-70 transition-opacity"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg></a>
					<a href="https://www.linkedin.com/in/mohamed-alzarzour/" target="_blank" style="color:var(--c-text3)" class="hover:opacity-70 transition-opacity"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a>
					<a href="https://www.instagram.com/moha5o/" target="_blank" style="color:var(--c-text3)" class="hover:opacity-70 transition-opacity"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg></a>
				</div>
			</div>
			<div class="mt-6 pt-4 flex flex-col sm:flex-row justify-between text-xs" style="border-top:1px solid var(--c-border); color:var(--c-text3)">
				<p>&copy; {new Date().getFullYear()} OptiType &middot; Mohamed Alzarzour</p>
				<p>ML-Powered Eye Tracking Typing System</p>
			</div>
		</div>
	</footer>

	<script>
	document.addEventListener('DOMContentLoaded',()=>{
		/* == Neural network background == */
		const canvas=document.getElementById('neural-bg');
		const ctx=canvas.getContext('2d');
		let W,H,nodes=[],mouse={x:-1000,y:-1000};
		function resize(){W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight;initNodes();}
		function initNodes(){nodes=[];const count=Math.min(60,Math.floor(W*H/18000));for(let i=0;i<count;i++){nodes.push({x:Math.random()*W,y:Math.random()*H,vx:(Math.random()-.5)*.3,vy:(Math.random()-.5)*.3,r:Math.random()*2+1});}}
		function drawNet(){ctx.clearRect(0,0,W,H);const isDark=document.documentElement.dataset.theme!=='light';
		for(let i=0;i<nodes.length;i++){const n=nodes[i];n.x+=n.vx;n.y+=n.vy;if(n.x<0||n.x>W)n.vx*=-1;if(n.y<0||n.y>H)n.vy*=-1;
		// mouse attraction
		const dx=mouse.x-n.x,dy=mouse.y-n.y,dist=Math.sqrt(dx*dx+dy*dy);
		if(dist<200){n.x+=dx*0.002;n.y+=dy*0.002;}
		ctx.beginPath();ctx.arc(n.x,n.y,n.r,0,Math.PI*2);ctx.fillStyle=isDark?'rgba(24,160,248,0.4)':'rgba(24,160,248,0.5)';ctx.fill();
		for(let j=i+1;j<nodes.length;j++){const m=nodes[j];const d=Math.hypot(n.x-m.x,n.y-m.y);if(d<150){ctx.beginPath();ctx.moveTo(n.x,n.y);ctx.lineTo(m.x,m.y);ctx.strokeStyle=isDark?`rgba(24,160,248,${0.15*(1-d/150)})`:`rgba(24,160,248,${0.2*(1-d/150)})`;ctx.lineWidth=0.5;ctx.stroke();}}}
		requestAnimationFrame(drawNet);}
		resize();window.addEventListener('resize',resize);
		document.addEventListener('mousemove',e=>{mouse.x=e.clientX;mouse.y=e.clientY;});
		drawNet();

		/* == Cursor glow == */
		const glow=document.getElementById('cursor-glow');
		let gx=0,gy=0,cx=0,cy=0;
		document.addEventListener('mousemove',e=>{gx=e.clientX;gy=e.clientY;});
		(function raf(){cx+=(gx-cx)*.06;cy+=(gy-cy)*.06;if(glow)glow.style.transform=`translate(${cx-300}px,${cy-300}px)`;requestAnimationFrame(raf);})();

		/* == Scroll reveals == */
		const obs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('on');});},{threshold:.08});
		document.querySelectorAll('.rv,.rv-l,.rv-r,.stg').forEach(el=>obs.observe(el));

		/* == Nav scroll == */
		const nav=document.getElementById('nav');
		const nd=nav.querySelector('div');
		window.addEventListener('scroll',()=>{
			if(window.scrollY>60){nav.style.background='var(--c-bg2)';nav.style.borderBottom='1px solid var(--c-border)';nav.style.backdropFilter='blur(20px)';nd.style.padding='0.6rem 1.25rem';}
			else{nav.style.background='transparent';nav.style.borderBottom='none';nav.style.backdropFilter='none';nd.style.padding='1.25rem';}
		});

		/* == Mobile menu == */
		const mb=document.getElementById('mob-btn'),mc=document.getElementById('mob-cl'),mm=document.getElementById('mob-menu'),mbd=document.getElementById('mob-bd'),mp=document.getElementById('mob-pn');
		function oM(){mm.classList.replace('pointer-events-none','pointer-events-auto');mbd.classList.replace('opacity-0','opacity-100');mp.classList.replace('translate-x-full','translate-x-0');}
		function cM(){mm.classList.replace('pointer-events-auto','pointer-events-none');mbd.classList.replace('opacity-100','opacity-0');mp.classList.replace('translate-x-0','translate-x-full');}
		mb?.addEventListener('click',oM);mc?.addEventListener('click',cM);mbd?.addEventListener('click',cM);

		/* == Theme toggle == */
		const tb=document.getElementById('theme-btn');
		const saved=localStorage.getItem('theme');
		if(saved)document.documentElement.dataset.theme=saved;
		tb?.addEventListener('click',()=>{
			const cur=document.documentElement.dataset.theme;
			const next=cur==='dark'?'light':'dark';
			document.documentElement.dataset.theme=next;
			localStorage.setItem('theme',next);
			document.querySelector('meta[name="theme-color"]').content=next==='dark'?'#06080e':'#f4f6fb';
		});

		/* == Tilt cards == */
		document.querySelectorAll('.tilt').forEach(c=>{
			c.addEventListener('mousemove',e=>{const r=c.getBoundingClientRect();const x=(e.clientX-r.left)/r.width-.5;const y=(e.clientY-r.top)/r.height-.5;c.style.transform=`perspective(600px) rotateY(${x*6}deg) rotateX(${-y*6}deg) scale(1.01)`;});
			c.addEventListener('mouseleave',()=>{c.style.transform='';});
		});
	});
	</script>
</body>
</html>
